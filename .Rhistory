#### Carga y transofarmacion  ####
# library(showtext)
library(shiny)
library(shinydashboard)
library(bsicons)
library(bslib)
library(htmltools)
library(readr)
library(jsonlite)
library(purrr)
library(DT)
endpoints <- "https://five.epicollect.net/api/export/entries/plan-de-arbolado-parana-2024-2028?form_ref=d82673133a804a53bf373c6c41be5f99_6821e5dd2ef80&branch_ref=d82673133a804a53bf373c6c41be5f99_6821e5dd2ef80_6821e6b4761cf"
all_data <- list()
library(httr)
for (endpoint in endpoints) {
# Hacer la solicitud GET
response <- GET(endpoint)
# Verificar si la solicitud fue exitosa
if (status_code(response) == 200) {
# Parsear el JSON de la respuesta a una lista
data <- fromJSON(content(response, as = "text"))
# Almacenar los datos en la lista all_data
all_data[[endpoint]] <- data
} else {
warning(paste("Error al acceder al endpoint:", endpoint, "- CÃģdigo de estado:", status_code(response)))
}
}
