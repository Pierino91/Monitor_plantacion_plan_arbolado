)
return(escuelas_mapa)
} else {
showNotification("Error al cargar los datos desde la API.", type = "error")
return(NULL)
}
}
alumnos_tiempo <- escuelas %>% select(fecha, cant_alumnos) %>%
arrange(fecha) %>%
mutate(
sumaAcumulada= cumsum(cant_alumnos)
)%>%
filter(!is.na(fecha))
# graphAlumnosALoLargoDelTiempo <-
ggplot(alumnos_tiempo, aes(x=fecha))+
geom_col(aes(y=cant_alumnos))+
geom_line(aes(y=sumaAcumulada), linewidth=0.8)+
geom_point(aes(y=sumaAcumulada), size = 1.5)+
labs(
title = "Sensibilización a lo largo del tiempo",
subtitle = "Ciudad de Parana",
x = "fecha",
y = "alumnos")+
theme_bw()
