Ovitrampa_resumen      <- ovitrampa_data %>%
select(
where(~ !all(is.na(.)))
)%>%
pivot_longer(cols = starts_with("CON"),
names_to = "Condicion",
values_to = "Valor"
)%>%
group_by(
Semana
)%>%
reframe(
Semana = as.Date(Semana),
total_CON_no_NA =  n_distinct(Condicion[!is.na(Valor)]),  # Cuenta cuántos valores no son NA
positivos = sum(Valor > 0, na.rm = TRUE),  # Cuenta valores positivos
IPO = round( positivos * 100 / ( total_CON_no_NA - 1), 2),
cant_huevos = sum(Valor[Valor > 0], na.rm = TRUE),  # Suma solo valores positivos
DH = round(cant_huevos / ifelse(positivos > 0, positivos, NA),2)  # Evita división por 0
)%>%
distinct(
)%>%
select(
Semana, IPO, DH
)
