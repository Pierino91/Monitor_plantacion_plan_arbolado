# Proyecto: VisualizaciÃģn de Plantaciones de Ãrboles en ParanÃĄ (2024-2028)
# Autor: Pierino Martin Goette
#### Funciones ####
get_all_entries <- function(base_url) {
all_entries <- tibble()  # Inicializar el tibble vacÃ­o
all_lugar <- tibble()    # Inicializar el tibble para coordenadas si existen
# Obtener el primer conjunto de datos
operarios_crudo_get <- get_data(base_url)
# operarios_crudo_get <- get_data(all_data$`https://five.epicollect.net/api/export/entries/escuela-separacion-de-residuos?form_ref=1e5048d2af5c4071b39e53e008ba5935_64429dd5c8e88`$links$first)
while (!is.null(operarios_crudo_get$links$self)) {
if (!is.null(operarios_crudo_get$data$entries)) {
# Convertir a tibble
entries <- as_tibble(operarios_crudo_get$data$entries)
# Convertir todas las columnas numÃĐricas a character
entries <- entries %>%
mutate(across(where(is.numeric), as.character))
# Detectar si hay una columna con datos de ubicaciÃģn y procesarla
col_lugar <- names(entries)[sapply(entries, is.list)]
if (length(col_lugar) > 0) {
# Extraer datos de latitud, longitud y precisiÃģn
lugar_df <- entries[col_lugar] %>%
map_dfr(~ tibble(
latitude = as.character(.x$latitude),
longitude = as.character(.x$longitude),
accuracy = as.character(.x$accuracy)
))
all_lugar <- bind_rows(all_lugar, lugar_df)
# Eliminar la columna de ubicaciÃģn del dataframe original
entries <- select(entries, -all_of(col_lugar))
}
# Acumular los datos
all_entries <- bind_rows(all_entries, entries)
}
# Obtener el siguiente enlace
next_link <- operarios_crudo_get$links$`next`
# Si no hay mÃĄs pÃĄginas, salir del bucle
if (is.null(next_link)) {
break
}
# Obtener el siguiente conjunto de datos
operarios_crudo_get <- get_data(next_link)
Sys.sleep(1)
}
# Retornar los datos combinados si existe informaciÃģn de ubicaciÃģn
if (nrow(all_lugar) > 0) {
return(cbind(all_entries, all_lugar))
} else {
return(all_entries)
}
}
get_data <- function(url) {
response <- GET(url)
if (status_code(response) == 200) {
content <- fromJSON(content(response, as = "text"))
return(content)
} else {
warning(paste("Error al acceder al enlace:", url, " - CÃģdigo de estado: ", status_code(response)))
return(NULL)
}
}
library(ggplot2)
tema <-
theme(
text = element_text(family = "Montserrat"),  # Fuente general
plot.title = element_text(
size = 20, face = "bold", color = "#4caf50", hjust = 0.5
),  # TÃ­tulo principal
plot.subtitle = element_text(
size = 14, face = "italic", hjust = 0.5
),  # SubtÃ­tulo
axis.title = element_text(
size = 12, face = "bold", color = "#007aff"
),  # Etiquetas de los ejes
axis.text = element_text(
size = 10, color = "black"
),  # Texto de los ejes
legend.title = element_text(
size = 12, face = "bold"
),  # TÃ­tulo de la leyenda
legend.text = element_text(size = 10),
plot.background = element_rect(
fill = "white", color = NA
),  # Fondo del grÃĄfico
panel.border = element_rect(
fill = NA, color = "#4caf50", linewidth = 1, linetype = "solid"
)  # Borde del panel
)
