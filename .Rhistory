# Variables
FACTOR_CAPTURA_POR_ARBOL  <- 30
factor_de_captura_carbono <- nrow(plantaciones_arboles) * FACTOR_CAPTURA_POR_ARBOL
META_ANUAL_PLANTACION  <- 2000
# Historico #####
plantaciones_especies_tiempo <-
plantaciones_arboles %>%
select(
fecha_hora_arbol_relevado, especie
) %>%
filter(!is.na(fecha_hora_arbol_relevado)
) %>%
arrange(
fecha_hora_arbol_relevado
) %>%
mutate(
mes = floor_date(fecha_hora_arbol_relevado, "month"),
mes = month(fecha_hora_arbol_relevado, label = TRUE, abbr = FALSE)
) %>%
group_by(
mes, especie
) %>%
reframe(
n_especies = n()
)
plantaciones_tiempo<-
plantaciones_especies_tiempo %>%
ungroup(
)%>%
group_by(
mes
)%>%
reframe(
n = sum(n_especies),
acumulado = cumsum(n)
)
cant_arboles_total <- plantaciones_arboles %>%
reframe(
total = n()
)
library(ggplot2)
grafica_plantaciones_arboles_tiempo <-
ggplot()+
geom_col(data = plantaciones_especies_tiempo, aes(x = mes,
y = n_especies,
fill = especie)
)+
geom_line(data = plantaciones_tiempo,
aes(
x=mes,
y=acumulado),
linewidth=0.8)+
geom_point(data = plantaciones_tiempo, aes(
x = mes,
y = acumulado),
size = 1.5)+
# guides(fill = FALSE)+
labs(
# title = "PlantaciÃģn de arbolado a lo largo del tiempo",
# subtitle = "Ciudad de ParanÃĄ - 2023 a 2027",
x = "fecha",
y = "arboles",
fill = "Especies")+
